# =============================================================================
# Groeax Trading Journal — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── Database (required) ──────────────────────────────────────────────────────
# Supabase: Project Settings → Database → Connection string → URI
# Use the "Session mode" pooler URL (port 5432) for long-lived Node.js servers.
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Auth (required) ──────────────────────────────────────────────────────────
# Random secret used to sign JWTs. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# ── Server (required) ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS (required in production) ────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# Example: https://myapp.vercel.app,https://www.myapp.com
# Use * for development only.
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ── Public URL (used in email/payment links) ─────────────────────────────────
# Set to the base URL of your deployed API server.
PUBLIC_URL=https://your-api.railway.app

# ── Frontend API base (Vite build-time only) ─────────────────────────────────
# Set this when building the frontend for Vercel so it points at the API server.
# Leave empty for local dev — the Vite dev proxy handles /api → localhost:5000.
VITE_API_URL=https://your-api.railway.app

# ── Payments — USDT TRC20 (required for subscription) ───────────────────────
USDT_TRC20_WALLET=your-trc20-wallet-address
BINANCE_MERCHANT_ID=your-binance-merchant-id

# ── AI / LLM APIs ────────────────────────────────────────────────────────────
# OpenAI (used by AI Coach, signal scoring)
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...

# Groq (fast inference alternative)
GROQ_API_KEY=gsk_...

# Google Gemini
GEMINI_API_KEY=AIza...

# ── Email Notifications ──────────────────────────────────────────────────────
EMAIL_SMTP_USER=your@email.com
EMAIL_SMTP_PASSWORD=your-smtp-app-password
ADMIN_EMAIL=admin@yourapp.com

# SendGrid (optional alternative to SMTP)
# SENDGRID_API_KEY=SG...

# ── WhatsApp Notifications (CallMeBot) ───────────────────────────────────────
CALLMEBOT_APIKEY_1=your-callmebot-key-1
CALLMEBOT_APIKEY_2=your-callmebot-key-2

# ── MongoDB (optional — all auth/trade routes use PostgreSQL) ────────────────
# The app runs fully without MongoDB. Only enable if you use the /api/mongo/* routes.
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/groeax

# ── Google OAuth (optional — for Gmail sending) ──────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
